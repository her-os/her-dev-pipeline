+                *self.workspace_root.write().await = workspace_root.clone();
+                let output = format!(
+                    "# Workspace Root\n\nworkspace_root={}\nlanguages={:?}\n\nSubsequent LSP tools in this MCP session resolve relative paths from this directory. Other AI sessions are unaffected; new sessions still default to their startup directory.",
