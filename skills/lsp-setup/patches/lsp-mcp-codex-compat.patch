+            tool = "setWorkspaceRoot",
+            path = %params.path,
+            "Processing tool request"
+        );
+
+        let current_root = self.workspace_root.read().await.clone();
+        let requested = PathBuf::from(params.path.trim());
+        let target = if requested.is_absolute() {
+            requested
+        } else {
+            current_root.join(requested)
+        };
+
+        let workspace_root = match target.canonicalize() {
+            Ok(path) if path.is_dir() => path,
+            Ok(path) => {
+                return Ok(self.wrap_output(
+                    request_id,
+                    tool_result_error(format!(
+                        "workspace root must be a directory, got: {}",
+                        path.display()
+                    )),
+                ));
+            }
+            Err(err) => {
+                return Ok(self.wrap_output(
+                    request_id,
+                    tool_result_error(format!(
+                        "failed to resolve workspace root '{}': {}",
+                        target.display(),
+                        err
+                    )),
+                ));
+            }
+        };
+
+        match self.service.set_workspace_root(&workspace_root).await {
