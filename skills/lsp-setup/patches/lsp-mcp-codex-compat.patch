+                );
+                Ok(self.wrap_output(request_id, tool_result_success(output)))
+            }
+            Err(err) => Ok(self.wrap_output(
+                request_id,
+                tool_result_error(format!(
+                    "failed to switch workspace root to '{}': {}",
+                    workspace_root.display(),
+                    err
+                )),
+            )),
+        }
+    }
