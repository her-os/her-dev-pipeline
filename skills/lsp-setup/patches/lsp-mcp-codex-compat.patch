+fn char_to_byte_index(text: &str, char_index: usize) -> usize {
+    if char_index == 0 {
+        return 0;
+    }
+
+    text.char_indices()
+        .nth(char_index)
+        .map(|(byte_index, _)| byte_index)
+        .unwrap_or(text.len())
+}
+
+fn slice_by_char_range(text: &str, start_char: usize, end_char: usize) -> &str {
+    let start_byte = char_to_byte_index(text, start_char);
+    let end_byte = char_to_byte_index(text, end_char.max(start_char));
+    text.get(start_byte..end_byte).unwrap_or("")
+}
+
+fn slice_from_char(text: &str, start_char: usize) -> &str {
+    let start_byte = char_to_byte_index(text, start_char);
+    text.get(start_byte..).unwrap_or("")
+}
+
+fn slice_to_char(text: &str, end_char: usize) -> &str {
+    let end_byte = char_to_byte_index(text, end_char);
+    text.get(..end_byte).unwrap_or("")
+}
